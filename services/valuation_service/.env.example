# Valuation Engine Configuration

# Application Settings
VE_APP_NAME=valuation-engine
VE_ENVIRONMENT=local
VE_API_PREFIX=/api
VE_API_VERSION=v1

# Database Configuration (PostgreSQL)
VE_POSTGRES_HOST=localhost
VE_POSTGRES_PORT=5432
VE_POSTGRES_USER=postgres
VE_POSTGRES_PASSWORD=postgres
VE_POSTGRES_DB=valuation_engine

# CSE API Configuration
VE_CSE_BASE_URL=https://www.cse.lk
VE_CSE_API_KEY=
VE_HTTP_TIMEOUT_SECONDS=15

# Gemini AI Configuration (for PDF extraction)
# Get your API key from: https://makersuite.google.com/app/apikey
VE_GEMINI_API_KEY=your_gemini_api_key_here
VE_GEMINI_MODEL=gemini-1.5-pro
